# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Security ────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 48
JWT_SECRET=8f2a9c4e7b1d6f3a0e5c8b2d7f4a1e6c9b3d8f2a5e7c1b4d9f6a3e8c2b5d7f1a

